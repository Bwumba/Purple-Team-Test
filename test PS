whoami /priv
get-localuser
get-netipaddress
$searcher = New-Object System.DirectoryServices.DirectorySearcher
$searcher.Filter = "(objectClass=*)"
$searcher.PageSize = 30
$results = $searcher.FindAll()

$results |
    ForEach-Object {
        $props = $_.Properties
        $obj = New-Object PSObject

        foreach ($key in $props.Keys) {
           $value = ($props[$key] -join ";")
           $obj | Add-Member -NotePropertyName $key -NotePropertyName $value
        }


    }  |
    Export-Csv  -NoTypeInformation -Path $env:temp\export.csv
